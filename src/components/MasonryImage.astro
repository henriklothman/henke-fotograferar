---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  title?: string;
  aspect?: string;
  width?: number;
  height?: number;
  href?: string;
  bgClass?: string;
  className?: string;
}

const { src, alt, title, aspect = '3 / 4', width = 1200, height = 900, href, bgClass = 'bg-slate-100', className = '' } = Astro.props;
const linkAriaLabel = title ? `Open photo: ${title}` : `Open photo: ${alt}`;
const isExternalUrl = typeof src === 'string';
---

<figure
  class={`group relative w-full overflow-hidden ${bgClass} ${className}`}
  style={`aspect-ratio: ${aspect};`}
>
  {href ? (
    <a href={href} aria-label={linkAriaLabel} class="masonry-link block h-full w-full">
      {isExternalUrl ? (
        <img
          src={src}
          alt={alt}
          width={width}
          height={height}
          class="masonry-photo h-full w-full object-cover"
          data-masonry-photo
          loading="lazy"
          onload="this.classList.add('is-loaded')"
          onerror="this.classList.add('is-loaded')"
        />
      ) : (
        <Image
          src={src}
          alt={alt}
          width={width}
          height={height}
          class="masonry-photo h-full w-full object-cover"
          data-masonry-photo
          loading="lazy"
          onload="this.classList.add('is-loaded')"
          onerror="this.classList.add('is-loaded')"
        />
      )}
    </a>
  ) : (
    isExternalUrl ? (
      <img
        src={src}
        alt={alt}
        width={width}
        height={height}
        class="masonry-photo h-full w-full object-cover"
        data-masonry-photo
        loading="lazy"
        onload="this.classList.add('is-loaded')"
        onerror="this.classList.add('is-loaded')"
      />
    ) : (
      <Image
        src={src}
        alt={alt}
        width={width}
        height={height}
        class="masonry-photo h-full w-full object-cover"
        data-masonry-photo
        loading="lazy"
        onload="this.classList.add('is-loaded')"
        onerror="this.classList.add('is-loaded')"
      />
    )
  )}
  {
    title ? (
      <figcaption class="pointer-events-none absolute inset-0 flex items-center justify-center bg-white/35 px-4 py-3 text-center text-stone-100 opacity-0 transition-opacity duration-200 group-hover:opacity-100 group-focus-within:opacity-100">
        <span class="bg-black/65 px-3 py-1.5 text-xl font-medium leading-tight backdrop-blur-md">{title}</span>
      </figcaption>
    ) : null
  }
</figure>

<script is:inline>
  (() => {
    if (window.__masonryPriorityInit === true) return;
    window.__masonryPriorityInit = true;

    const viewportPromotionMargin = window.matchMedia('(max-width: 767px)').matches ? '200px 0px' : '120px 0px';
    const photos = document.querySelectorAll('img[data-masonry-photo]');
    if (!photos.length) return;

    const promote = (img) => {
      if (!(img instanceof HTMLImageElement)) return;
      if (img.dataset.priorityApplied === 'true') return;
      img.loading = 'eager';
      img.fetchPriority = 'high';
      img.decoding = 'async';
      img.dataset.priorityApplied = 'true';
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          promote(entry.target);
          observer.unobserve(entry.target);
        });
      },
      { root: null, rootMargin: viewportPromotionMargin, threshold: 0.01 },
    );

    photos.forEach((img) => observer.observe(img));
  })();
</script>

<style>
  .masonry-photo {
    opacity: 0;
    transform: scale(1);
    transition: opacity 420ms ease-out, transform 3400ms cubic-bezier(0.16, 0.78, 0.2, 1);
    will-change: opacity, transform;
  }

  .masonry-photo.is-loaded {
    opacity: 1;
  }

  .group:hover .masonry-photo,
  .group:focus-within .masonry-photo {
    transform: scale(1.16);
  }

  .masonry-link:focus-visible {
    outline: 3px solid #111827;
    outline-offset: -3px;
  }

  html[data-theme='dark'] .masonry-link:focus-visible {
    outline-color: #ffffff;
  }

  html[data-theme='dark'] .masonry-photo {
    filter: grayscale(1);
  }
</style>
