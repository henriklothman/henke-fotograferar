---
import Linkedin from '../assets/linkedin.svg';
import Instagram from '../assets/instagram.svg';
---

<footer class="footer-mark">
  <a
    class="footer-mark__link"
    href="https://www.linkedin.com/in/henriklothman/"
    target="_blank"
    rel="noreferrer noopener"
    aria-label="LinkedIn"
  >
    <span class="footer-mark__icon" aria-hidden="true" style={`--icon-url: url('${Linkedin.src}');`}></span>
  </a>
  <a
    class="footer-mark__link"
    href="https://www.instagram.com/henriklot/"
    target="_blank"
    rel="noreferrer noopener"
    aria-label="Instagram"
  >
    <span class="footer-mark__icon" aria-hidden="true" style={`--icon-url: url('${Instagram.src}');`}></span>
  </a>
</footer>

<style>
  .footer-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    max-width: 80rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 6rem;
  }

  .footer-mark__link {
    display: inline-flex;
    align-items: center;
    min-height: 16px;
    font-size: 0.875rem;
    line-height: 1;
    color: #64748b;
  }

  .footer-mark__link {
    text-decoration: none;
  }

  .footer-mark__icon {
    display: inline-block;
    width: 30px;
    height: 30px;
    background-color: currentColor;
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  html[data-theme='dark'] .footer-mark__link {
    color: #94a3b8;
  }
</style>
