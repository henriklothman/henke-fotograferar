---
import Logo from '../assets/logo_light.svg';
import LogoDark from '../assets/logo_dark.svg';
import HenksLogo from '../assets/henks.png';
import Cross from '../assets/cross.svg';
import MoonStar from '../assets/moon_star.svg';
import Sun from '../assets/sun.svg';

interface Props {
  className?: string;
  activeTab?: 'photography' | 'folks' | 'about';
  photoNav?: {
    items: Array<{
      title: string;
      href?: string;
      active?: boolean;
    }>;
  };
}

const { className = '', activeTab = 'photography', photoNav } = Astro.props;
const subNavItems = photoNav?.items ?? [];
const isAboutTab = activeTab === 'about';
---

<div class={`nav-shell w-full ${className}`} data-name="NavShell">
<nav class="nav-root relative flex w-full flex-col items-center gap-4 sm:flex-row sm:items-center sm:justify-between" data-name="Nav">
  <a href="/" aria-label="Go to Photography home" class="nav-logo nav-focusable relative h-18 w-18 shrink-0 rounded-sm">
    {
      isAboutTab ? (
        <img alt="Henrik Löthman" class="absolute inset-0 h-full w-full object-cover" src={HenksLogo.src} />
      ) : (
        <>
          <img alt="Henrik Löthman" class="theme-logo-light absolute inset-0 h-full w-full object-cover" src={Logo.src} />
          <img alt="Henrik Löthman" class="theme-logo-dark absolute inset-0 h-full w-full object-cover" src={LogoDark.src} />
        </>
      )
    }
  </a>

  <div class="w-full sm:w-auto">
    <div class="grid w-full grid-cols-[auto_auto_auto] items-center justify-center gap-x-5 sm:w-auto sm:justify-start sm:gap-x-7">
      <a
        href="/"
        aria-label="Go to Photography"
        class="nav-main-link nav-focusable col-start-1 row-start-1 flex items-center gap-2.5 rounded-sm px-1 py-0.5"
        data-inactive={activeTab !== 'photography'}
      >
        {
          photoNav && activeTab === 'photography' ? (
            <span
              aria-hidden="true"
              class="nav-cross icon-mask block h-2.5 w-2.5 bg-black opacity-90"
              style={`--icon-url: url('${Cross.src}');`}
            ></span>
          ) : (
            <div
              class={`nav-active-dot nav-main-dot h-1.75 w-1.75 rounded-full bg-black transition-opacity ${activeTab === 'photography' ? 'opacity-100' : 'opacity-0'}`}
            ></div>
          )
        }
        <p class={`nav-main-label text-base leading-none whitespace-nowrap ${activeTab === 'photography' ? 'font-medium text-black' : 'font-normal text-slate-500'}`}>
          Photography
        </p>
      </a>

      <a
        href="/about"
        aria-label="Go to About"
        class="nav-main-link nav-focusable col-start-2 row-start-1 flex items-center gap-2.5 rounded-sm px-1 py-0.5"
        data-inactive={activeTab !== 'about'}
      >
        <div class={`nav-active-dot nav-main-dot h-1.75 w-1.75 rounded-full bg-black transition-opacity ${activeTab === 'about' ? 'opacity-100' : 'opacity-0'}`}></div>
        <p class={`nav-main-label text-base leading-none whitespace-nowrap ${activeTab === 'about' ? 'font-medium text-black' : 'font-normal text-slate-500'}`}>About</p>
      </a>

      <button
        type="button"
        aria-label="Toggle light and dark mode"
        data-theme-toggle
        class="nav-focusable col-start-3 row-start-1 flex h-8 w-8 cursor-pointer items-center justify-center rounded-sm"
      >
        <span
          data-theme-icon
          data-icon-on={Sun.src}
          data-icon-off={MoonStar.src}
          class="icon-mask block h-5 w-5 bg-black transition-colors"
          style={`--icon-url: url('${MoonStar.src}');`}
        ></span>
      </button>
    </div>

    {
      photoNav ? (
        <div class="nav-subitems mt-3 ml-0.5">
          {
            subNavItems.map((item, index) => {
              const isLast = index === subNavItems.length - 1;
              const connectorClass = isLast ? 'after:h-1/2' : 'after:h-full';

              return item.href ? (
                <a
                  href={item.href}
                  class={`nav-subitem-link nav-focusable relative flex items-center gap-3 rounded-sm py-1 pl-4 text-sm leading-snug transition-colors before:absolute before:left-0 before:top-1/2 before:h-0 before:w-3 before:-translate-y-1/2 before:border-t before:border-black after:absolute after:left-0 after:top-0 after:border-l after:border-black ${connectorClass} ${item.active ? 'font-medium text-black' : 'text-slate-500 hover:text-black'}`}
                  data-inactive={!item.active}
                >
                  <span>{item.title}</span>
                </a>
              ) : (
                <p class={`relative flex items-center gap-3 py-1 pl-4 text-sm leading-snug before:absolute before:left-0 before:top-1/2 before:h-0 before:w-3 before:-translate-y-1/2 before:border-t before:border-black after:absolute after:left-0 after:top-0 after:border-l after:border-black ${connectorClass} ${item.active ? 'font-medium text-black' : 'text-slate-500'}`}>
                  <span>{item.title}</span>
                </p>
              );
            })
          }
        </div>
      ) : null
    }
  </div>
</nav>
</div>

<script is:inline>
  (() => {
    const DESKTOP_QUERY = '(min-width: 768px)';
    const COMPACT_SCROLL_Y = 900;

    const initCompactNav = () => {
      const nav = document.querySelector('[data-name="Nav"]');
      if (!(nav instanceof HTMLElement)) return;
      const shell = nav.closest('[data-name="NavShell"]');
      if (!(shell instanceof HTMLElement)) return;

      const mediaQuery = window.matchMedia(DESKTOP_QUERY);
      const setShellHeight = () => {
        shell.style.setProperty('--nav-shell-height', `${nav.offsetHeight}px`);
      };

      const updateCompactState = () => {
        setShellHeight();

        if (!mediaQuery.matches) {
          nav.classList.remove('nav-compact');
          shell.classList.remove('nav-shell-compact');
          return;
        }

        if (window.scrollY > COMPACT_SCROLL_Y) {
          nav.classList.add('nav-compact');
          shell.classList.add('nav-shell-compact');
        } else {
          nav.classList.remove('nav-compact');
          shell.classList.remove('nav-shell-compact');
        }
      };

      setShellHeight();
      updateCompactState();
      window.addEventListener('scroll', updateCompactState, { passive: true });
      window.addEventListener('resize', updateCompactState);
      mediaQuery.addEventListener('change', updateCompactState);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCompactNav, { once: true });
    } else {
      initCompactNav();
    }
  })();
</script>

<style>
  .nav-root {
    transition: padding 180ms ease, gap 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .nav-logo {
    transition: width 180ms ease, height 180ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .nav-logo:hover {
    transform: rotate(15deg);
  }

  .nav-main-link[data-inactive='true'] .nav-main-label {
    transition: color 180ms ease;
  }

  .nav-main-link[data-inactive='true']:hover .nav-main-label {
    color: #111827;
  }

  html[data-theme='dark'] .nav-main-link[data-inactive='true']:hover .nav-main-label {
    color: #e5e7eb;
  }

  html[data-theme='dark'] .nav-subitem-link[data-inactive='true']:hover {
    color: #e5e7eb;
  }

  .icon-mask {
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  .theme-logo-dark {
    display: none;
  }

  html[data-theme='dark'] .theme-logo-light {
    display: none;
  }

  html[data-theme='dark'] .theme-logo-dark {
    display: block;
  }

  html[data-theme='dark'] [data-theme-icon] {
    background-color: #ffffff;
  }

  html[data-theme='dark'] .nav-active-dot {
    background-color: #ffffff;
  }

  html[data-theme='dark'] .nav-cross {
    background-color: #ffffff;
  }

  .nav-focusable:focus-visible {
    outline: 1px solid rgba(17, 24, 39, 0.35);
    outline-offset: 2px;
  }

  html[data-theme='dark'] .nav-focusable:focus-visible {
    outline-color: rgba(255, 255, 255, 0.45);
  }

  @media (min-width: 768px) {
    .nav-shell.nav-shell-compact {
      min-height: var(--nav-shell-height, 0px);
    }

    .nav-root.nav-compact {
      position: fixed;
      top: 10px;
      left: 0;
      right: 0;
      margin: 0 auto;
      z-index: 70;
      width: min(760px, calc(100vw - 24px));
      border-radius: 9999px;
      background: rgba(255, 255, 255, 0.68);
      backdrop-filter: blur(12px);
      padding: 0.45rem 0.56rem;
      gap: 0.6rem;
      animation: nav-compact-in 180ms ease-out;
    }

    .nav-root.nav-compact .nav-logo {
      width: 2.5rem;
      height: 2.5rem;
    }

    .nav-root.nav-compact .nav-subitems {
      display: none;
    }

    html[data-theme='dark'] .nav-root.nav-compact {
      background: rgba(2, 6, 23, 0.65);
    }
  }

  @keyframes nav-compact-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

</style>
