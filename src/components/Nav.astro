---
import Logo from '../assets/logo_light.svg';
import LogoDark from '../assets/logo_dark.svg';
import HenksLogo from '../assets/henks.png';
import Cross from '../assets/cross.svg';
import MoonStar from '../assets/moon_star.svg';
import Sun from '../assets/sun.svg';
import Instagram from '../assets/instagram.svg';
import Linkedin from '../assets/linkedin.svg';

interface Props {
  className?: string;
  activeTab?: 'photography' | 'folks' | 'about';
  photoNav?: {
    items: Array<{
      title: string;
      href?: string;
      active?: boolean;
    }>;
  };
}

const { className = '', activeTab = 'photography', photoNav } = Astro.props;
const subNavItems = photoNav?.items ?? [];
const isAboutTab = activeTab === 'about';
---

<div class={`nav-shell w-full ${className}`} data-name="NavShell">
<nav class="nav-root relative flex w-full flex-col gap-5 py-1.5 lg:pt-12 lg:pb-3" data-name="Nav">
  <div class="nav-top flex items-center justify-between lg:block">
    <a href="/" aria-label="Go to Photography home" class="nav-logo nav-focusable nav-reveal-item relative block h-18 w-18 shrink-0 rounded-sm" data-nav-reveal>
      {
        isAboutTab ? (
          <img alt="Henrik Löthman" class="absolute inset-0 h-full w-full object-cover" src={HenksLogo.src} />
        ) : (
          <>
            <img alt="Henrik Löthman" class="theme-logo-light absolute inset-0 h-full w-full object-cover" src={Logo.src} />
            <img alt="Henrik Löthman" class="theme-logo-dark absolute inset-0 h-full w-full object-cover" src={LogoDark.src} />
          </>
        )
      }
    </a>

    <button
      type="button"
      class="nav-mobile-toggle nav-focusable lg:hidden"
      data-nav-menu-toggle
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <span class="nav-mobile-toggle-line"></span>
      <span class="nav-mobile-toggle-line"></span>
      <span class="nav-mobile-toggle-line"></span>
    </button>
  </div>

  <div class="nav-menu w-full" data-nav-menu>
  <div class="nav-primary w-full">
    <a
      href="/"
      aria-label="Go to Photography"
      class="nav-main-link nav-focusable nav-reveal-item flex items-center gap-2.5 rounded-sm px-1 py-0.5"
      data-inactive={activeTab !== 'photography'}
      data-nav-reveal
    >
      {
        photoNav && activeTab === 'photography' ? (
          <span
            aria-hidden="true"
            class="nav-cross icon-mask block h-2.5 w-2.5 bg-black opacity-90"
            style={`--icon-url: url('${Cross.src}');`}
          ></span>
        ) : (
          null
        )
      }
      <p class={`nav-main-label text-base leading-none whitespace-nowrap ${activeTab === 'photography' ? 'font-medium text-black' : 'font-normal text-slate-500'}`}>
        Photography
      </p>
    </a>

    {
      photoNav ? (
        <div class="nav-subitems mt-3 ml-0.5">
          {
            subNavItems.map((item, index) => {
              const isLast = index === subNavItems.length - 1;
              const connectorClass = isLast ? 'after:h-1/2' : 'after:h-full';

              return item.href ? (
                <a
                  href={item.href}
                  class={`nav-subitem-link nav-focusable nav-reveal-item relative flex items-center gap-3 rounded-sm py-1 pl-4 text-sm leading-snug transition-colors before:absolute before:left-0 before:top-1/2 before:h-0 before:w-3 before:-translate-y-1/2 before:border-t before:border-black after:absolute after:left-0 after:top-0 after:border-l after:border-black ${connectorClass} ${item.active ? 'font-medium text-black' : 'text-slate-500 hover:text-black'}`}
                  data-inactive={!item.active}
                  data-nav-reveal
                >
                  <span>{item.title}</span>
                </a>
              ) : (
                <p class={`nav-reveal-item relative flex items-center gap-3 py-1 pl-4 text-sm leading-snug before:absolute before:left-0 before:top-1/2 before:h-0 before:w-3 before:-translate-y-1/2 before:border-t before:border-black after:absolute after:left-0 after:top-0 after:border-l after:border-black ${connectorClass} ${item.active ? 'font-medium text-black' : 'text-slate-500'}`} data-nav-reveal>
                  <span>{item.title}</span>
                </p>
              );
            })
          }
        </div>
      ) : null
    }

    <a
      href="/about"
      aria-label="Go to About"
      class="nav-main-link nav-focusable nav-reveal-item mt-4 flex items-center gap-2.5 rounded-sm px-1 py-0.5"
      data-inactive={activeTab !== 'about'}
      data-nav-reveal
    >
      <p class={`nav-main-label text-base leading-none whitespace-nowrap ${activeTab === 'about' ? 'font-medium text-black' : 'font-normal text-slate-500'}`}>About</p>
    </a>
  </div>

  <div class="nav-secondary w-full">
    <button
      type="button"
      aria-label="Toggle light and dark mode"
      data-theme-toggle
      class="nav-secondary-link nav-focusable nav-reveal-item mt-3 flex cursor-pointer items-center gap-2 rounded-sm px-1 py-0.5 text-sm text-slate-500 transition-colors hover:text-black"
      data-nav-reveal
    >
      <span
        data-theme-icon
        data-icon-on={Sun.src}
        data-icon-off={MoonStar.src}
        class="icon-mask block h-4 w-4 bg-current transition-colors"
        style={`--icon-url: url('${MoonStar.src}');`}
      ></span>
      <span data-theme-label data-label-on="Turns lights on" data-label-off="Turn lights off">Turn lights off</span>
    </button>

    <a
      href="https://www.instagram.com/henriklot/"
      target="_blank"
      rel="noreferrer noopener"
      aria-label="Instagram"
      class="nav-secondary-link nav-focusable nav-reveal-item mt-3 flex items-center gap-2 rounded-sm px-1 py-0.5 text-sm text-slate-500 transition-colors hover:text-black"
      data-nav-reveal
    >
      <span
        aria-hidden="true"
        class="icon-mask block h-4 w-4 bg-current"
        style={`--icon-url: url('${Instagram.src}');`}
      ></span>
      <span>Instagram</span>
    </a>

    <a
      href="https://www.linkedin.com/in/henriklothman/"
      target="_blank"
      rel="noreferrer noopener"
      aria-label="LinkedIn"
      class="nav-secondary-link nav-focusable nav-reveal-item mt-2 flex items-center gap-2 rounded-sm px-1 py-0.5 text-sm text-slate-500 transition-colors hover:text-black"
      data-nav-reveal
    >
      <span
        aria-hidden="true"
        class="icon-mask block h-4 w-4 bg-current"
        style={`--icon-url: url('${Linkedin.src}');`}
      ></span>
      <span>LinkedIn</span>
    </a>

    <p class="nav-reveal-item mt-4 hidden px-1 text-xs leading-relaxed text-slate-500 md:block" data-nav-reveal>
      Henrik Löthman is a Swedish product developer capturing quiet moments, light and structure.
    </p>
  </div>
  </div>
</nav>
</div>

<script is:inline>
  (() => {
    const SESSION_KEY = 'nav-reveal-played-v1';
    const DESKTOP_QUERY = '(min-width: 1024px)';

    const initNavReveal = () => {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const navs = document.querySelectorAll('[data-name="Nav"]');
      if (!navs.length) return;

      navs.forEach((nav) => {
        if (!(nav instanceof HTMLElement)) return;
        const revealItems = Array.from(nav.querySelectorAll('[data-nav-reveal]'));
        revealItems.forEach((item, index) => {
          if (item instanceof HTMLElement) {
            item.style.setProperty('--nav-reveal-index', String(index));
          }
        });

        let hasPlayed = false;
        try {
          hasPlayed = sessionStorage.getItem(SESSION_KEY) === '1';
        } catch {
          hasPlayed = false;
        }

        if (prefersReducedMotion || hasPlayed) {
          nav.classList.add('nav-reveal-done');
          return;
        }

        nav.classList.add('nav-animate-in');
        try {
          sessionStorage.setItem(SESSION_KEY, '1');
        } catch {
          // Ignore storage failures.
        }
      });
    };

    const initMobileMenu = () => {
      const navs = document.querySelectorAll('[data-name="Nav"]');
      if (!navs.length) return;

      navs.forEach((nav) => {
        if (!(nav instanceof HTMLElement)) return;
        const toggle = nav.querySelector('[data-nav-menu-toggle]');
        const menu = nav.querySelector('[data-nav-menu]');
        if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

        const desktopMedia = window.matchMedia(DESKTOP_QUERY);
        const setExpandedState = () => {
          if (desktopMedia.matches) {
            toggle.setAttribute('aria-expanded', 'true');
            return;
          }
          toggle.setAttribute('aria-expanded', nav.classList.contains('nav-menu-open') ? 'true' : 'false');
        };

        toggle.addEventListener('click', () => {
          nav.classList.toggle('nav-menu-open');
          setExpandedState();
        });

        menu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            if (desktopMedia.matches) return;
            nav.classList.remove('nav-menu-open');
            setExpandedState();
          });
        });

        desktopMedia.addEventListener('change', () => {
          if (desktopMedia.matches) {
            nav.classList.remove('nav-menu-open');
          }
          setExpandedState();
        });

        setExpandedState();
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        initMobileMenu();
        initNavReveal();
      }, { once: true });
    } else {
      initMobileMenu();
      initNavReveal();
    }
  })();
</script>

<style>
  .nav-root {
    transition: gap 180ms ease;
  }

  .nav-menu {
    display: none;
  }

  .nav-root.nav-menu-open .nav-menu {
    display: block;
  }

  .nav-mobile-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.28rem;
    min-height: 2.25rem;
    padding: 0.25rem 0.4rem;
    border-radius: 0.125rem;
    color: #64748b;
  }

  .nav-mobile-toggle-line {
    width: 1.2rem;
    height: 1px;
    background-color: currentColor;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .nav-root.nav-menu-open .nav-mobile-toggle-line:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }

  .nav-root.nav-menu-open .nav-mobile-toggle-line:nth-child(2) {
    opacity: 0;
  }

  .nav-root.nav-menu-open .nav-mobile-toggle-line:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  .nav-reveal-item {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-root.nav-animate-in .nav-reveal-item {
    opacity: 0;
    transform: translateY(8px);
    animation: nav-reveal-in 520ms ease-out forwards;
    animation-delay: calc(var(--nav-reveal-index, 0) * 70ms);
  }

  .nav-logo {
    transition: width 180ms ease, height 180ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .nav-logo:hover {
    transform: rotate(15deg);
  }

  .nav-main-link[data-inactive='true'] .nav-main-label {
    transition: color 180ms ease;
  }

  .nav-main-link[data-inactive='true']:hover .nav-main-label {
    color: #111827;
  }

  html[data-theme='dark'] .nav-main-link[data-inactive='true']:hover .nav-main-label {
    color: #e5e7eb;
  }

  html[data-theme='dark'] .nav-subitem-link[data-inactive='true']:hover {
    color: #e5e7eb;
  }

  html[data-theme='dark'] .nav-secondary-link {
    color: #94a3b8;
  }

  html[data-theme='dark'] .nav-secondary-link:hover {
    color: #e5e7eb;
  }

  html[data-theme='dark'] .nav-mobile-toggle {
    color: #94a3b8;
  }

  .icon-mask {
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  .theme-logo-dark {
    display: none;
  }

  html[data-theme='dark'] .theme-logo-light {
    display: none;
  }

  html[data-theme='dark'] .theme-logo-dark {
    display: block;
  }

  html[data-theme='dark'] .nav-cross {
    background-color: #ffffff;
  }

  .nav-focusable:focus-visible {
    outline: 1px solid rgba(17, 24, 39, 0.35);
    outline-offset: 2px;
  }

  html[data-theme='dark'] .nav-focusable:focus-visible {
    outline-color: rgba(255, 255, 255, 0.45);
  }

  @media (min-width: 1024px) {
    .nav-mobile-toggle {
      display: none;
    }

    .nav-menu {
      display: flex;
      flex: 1;
      flex-direction: column;
    }

    .nav-shell {
      align-self: start;
      position: sticky;
      top: 3rem;
      height: calc(100vh - 6rem);
    }

    .nav-primary {
      margin-top: 4.5rem;
    }

    .nav-root {
      min-height: 100%;
    }

    .nav-secondary {
      margin-top: auto;
    }
  }

  @keyframes nav-reveal-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-root.nav-animate-in .nav-reveal-item {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
