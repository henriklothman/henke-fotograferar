  html.photo-full #photo-page-section {
    padding-top: 0;
  }

  html.photo-full #photo-page-nav,
  html.photo-full #photo-meta,
  html.photo-full #photo-media-controls,
  html.photo-full #photo-nav-left,
  html.photo-full #photo-nav-right {
    display: none !important;
  }

  html.photo-full #photo-media-column {
    width: 100vw !important;
    max-width: none !important;
    margin: 0 !important;
  }

  html.photo-full #photo-media-container {
    margin-top: 0 !important;
    width: 100vw !important;
    max-width: none !important;
    height: 100svh !important;
    aspect-ratio: auto !important;
    background: transparent !important;
  }

  html.photo-full #photo-media-image {
    inset: 12px !important;
  }

  @media (min-width: 768px) {
    html.photo-full #photo-media-image {
      inset: 20px !important;
    }
  }

  html.photo-full #photo-media-image .photo-main-image {
    object-fit: contain !important;
    background: transparent;
  }

  @media (max-width: 767px) {
    #photo-media-container {
      width: 100% !important;
      height: auto !important;
