---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { Image } from 'astro:assets';
import placeholderImage from '../../assets/placeholder-image.svg';
import caretLeft from '../../assets/caret_left.svg';
import caretRight from '../../assets/caret_right.svg';
import cameraIcon from '../../assets/camera.svg';
import locationIcon from '../../assets/location.svg';
import crossIcon from '../../assets/cross.svg';
import henksMarker from '../../assets/henks.png';
import { getContentfulPhotos } from '../../lib/contentful';

const { id_of_the_photo } = Astro.params;
const photos = await getContentfulPhotos();
const selectedPhoto = photos.find((photo) => photo.id === id_of_the_photo);
const photoIds = photos.length > 0 ? photos.map((photo) => photo.id) : ['photo-1', 'photo-2', 'photo-3', 'photo-4', 'photo-5', 'photo-6', 'photo-7', 'photo-8', 'photo-9'];
const photoById = new Map(photos.map((photo) => [photo.id, photo]));
const currentIndexRaw = photoIds.indexOf(id_of_the_photo ?? '');
const currentIndex = currentIndexRaw >= 0 ? currentIndexRaw : 0;
const hasLoopCarouselNav = photoIds.length > 1;
const leftLoopId = hasLoopCarouselNav ? photoIds[(currentIndex - 1 + photoIds.length) % photoIds.length] : null;
const rightLoopId = hasLoopCarouselNav ? photoIds[(currentIndex + 1) % photoIds.length] : null;
const navWindowSize = Math.min(3, photoIds.length);
const navWindowStart = Math.max(0, Math.min(currentIndex - 1, photoIds.length - navWindowSize));
const navItems = photoIds.slice(navWindowStart, navWindowStart + navWindowSize).map((id) => {
  const photo = photoById.get(id);
  const isActive = id === id_of_the_photo;
  return {
    title: photo?.title ?? id,
    href: isActive ? undefined : `/photo/${encodeURIComponent(id)}`,
    active: isActive,
  };
});
const title = selectedPhoto?.title ?? id_of_the_photo;
const description = selectedPhoto?.description ?? '';
const location = selectedPhoto?.location;
const locationLat = selectedPhoto?.locationLat;
const locationLon = selectedPhoto?.locationLon;
const targetLocationLat = selectedPhoto?.targetLocationLat;
const targetLocationLon = selectedPhoto?.targetLocationLon;
const focalLength = selectedPhoto?.focalLength;
const shutterSpeed = selectedPhoto?.shutterSpeed;
const aperture = selectedPhoto?.aperture;
const iso = selectedPhoto?.iso;
const mediaAspectRatio = selectedPhoto ? `${selectedPhoto.width} / ${selectedPhoto.height}` : '16 / 10';
const isPortraitMedia = selectedPhoto ? selectedPhoto.height > selectedPhoto.width : false;
const mediaContentColumnClass = 'w-full';
const mediaContainerClass = isPortraitMedia ? 'photo-media-container--portrait' : '';
const mediaContainerStyle = isPortraitMedia
  ? `aspect-ratio: ${mediaAspectRatio}; width: auto; max-width: 100%; margin-inline: auto;`
  : `aspect-ratio: ${mediaAspectRatio};`;
const locationQuery =
  typeof locationLat === 'number' && typeof locationLon === 'number' ? `${locationLat},${locationLon}` : location;
const hasCoordinates = typeof locationLat === 'number' && typeof locationLon === 'number';
const googleMapsApiKey = import.meta.env.GOOGLE_MAPS_API_KEY ?? '';
const mapEmbedUrl =
  typeof locationLat === 'number' && typeof locationLon === 'number'
    ? `https://www.google.com/maps?ll=${locationLat},${locationLon}&z=15&output=embed`
    : locationQuery
      ? `https://www.google.com/maps?q=${encodeURIComponent(locationQuery)}&z=15&output=embed`
      : null;
const hasInteractiveMap = hasCoordinates;
const hasMapMedia = Boolean(hasInteractiveMap || mapEmbedUrl);
const mapMode = hasInteractiveMap ? 'interactive' : mapEmbedUrl ? 'fallback' : 'none';

function ensureUnit(value: string | undefined, suffix: string): string | undefined {
  if (!value) return undefined;
  const normalized = value.trim();
  return normalized.toLowerCase().endsWith(suffix.toLowerCase()) ? normalized : `${normalized}${suffix}`;
}

function formatShutter(value: string | undefined): string | undefined {
  if (!value) return undefined;
  const normalized = value.trim();
  return normalized.replace(/\s*sec(?:onds?)?\.?$/i, '').trim();
}

function formatAperture(value: string | undefined): string | undefined {
  if (!value) return undefined;
  const normalized = value.trim();
  if (normalized.length === 0) return undefined;
  const stripped = normalized.replace(/^[fƒ]\s*\/?\s*/i, '').trim();
  if (stripped.length === 0) return undefined;
  return `ƒ/${stripped}`;
}

const focalLengthText = ensureUnit(focalLength, 'mm');
const shutterSpeedText = formatShutter(shutterSpeed);
const apertureText = formatAperture(aperture);
const isoText = iso ? `ISO ${iso}` : undefined;
const exposurePrimary = focalLengthText
  ? `${focalLengthText}${apertureText ? ` @ ${apertureText}` : ''}`
  : apertureText;
const exposureDetails = [exposurePrimary, shutterSpeedText, isoText].filter(Boolean).join(', ');
const exposureLine = exposureDetails ? `${title} → ${exposureDetails}` : null;
const isInitialFull = Astro.url.searchParams.get('full') === '1' || Astro.url.searchParams.get('immersive') === '1';
---

<Layout title={`${title} | hnrik.com`} description={description} htmlClass={isInitialFull ? 'photo-full' : ''}>
  <main id="photo-page-main" class="w-full p-4 sm:p-10 lg:p-12">
    <div class="lg:grid lg:grid-cols-[minmax(180px,16%)_minmax(0,1fr)] lg:gap-x-12">
      <div id="photo-page-nav">
        <Nav
          activeTab="photography"
          photoNav={{
            items: navItems,
          }}
        />
      </div>

      <section id="photo-page-section" class="pt-6 lg:pt-0 photo-page-section--desktop-loading">
        <div id="photo-media-column" class={mediaContentColumnClass}>
        <div id="photo-media-container" data-aspect-ratio={selectedPhoto ? selectedPhoto.width / selectedPhoto.height : undefined} class:list={['group/media relative mt-4 overflow-hidden bg-stone-200', mediaContainerClass]} style={mediaContainerStyle}>
        <div id="photo-media-controls" class="absolute top-4 right-4 z-40 flex items-center gap-3 rounded-full bg-white px-4 py-2 transition-opacity md:pointer-events-none md:opacity-0 md:group-hover/media:pointer-events-auto md:group-hover/media:opacity-100 md:group-focus-within/media:pointer-events-auto md:group-focus-within/media:opacity-100">
          {
            leftLoopId && rightLoopId ? (
              <>
                <a id="photo-nav-left" data-photo-prev href={`/photo/${encodeURIComponent(leftLoopId)}`} aria-label="Previous photo" class="group cursor-pointer transition-opacity hover:opacity-70">
                  <span class="icon-mask control-overlay-muted-icon block h-3 w-3 transition-colors group-hover:bg-black" style={`--icon-url: url('${caretLeft.src}');`}></span>
                </a>
                <a id="photo-nav-right" data-photo-next href={`/photo/${encodeURIComponent(rightLoopId)}`} aria-label="Next photo" class="group cursor-pointer transition-opacity hover:opacity-70">
                  <span class="icon-mask control-overlay-muted-icon block h-3 w-3 transition-colors group-hover:bg-black" style={`--icon-url: url('${caretRight.src}');`}></span>
                </a>
              </>
            ) : null
          }
          <button id="show-photo-button" type="button" aria-label="Show photo" class="group cursor-pointer transition-opacity hover:opacity-70">
            <span id="camera-icon" class="control-icon-active icon-mask block h-4 w-4 transition-colors" style={`--icon-url: url('${cameraIcon.src}');`}></span>
          </button>
          <button
            id="show-map-button"
            type="button"
            aria-label="Show map"
            class="group cursor-pointer transition-opacity hover:opacity-70"
          >
            <span id="location-icon" class="control-icon-inactive icon-mask block h-4 w-4 transition-colors" style={`--icon-url: url('${locationIcon.src}');`}></span>
          </button>
          <a href="/" aria-label="Back to gallery" class="group cursor-pointer">
            <span class="icon-mask control-overlay-muted-icon block h-3 w-3 transition-colors group-hover:bg-black" style={`--icon-url: url('${crossIcon.src}');`}></span>
          </a>
        </div>
        {
          selectedPhoto ? (
            <div id="photo-media-image" class="absolute inset-0 z-0">
              <img
                src={selectedPhoto.imageUrl}
                alt={selectedPhoto.alt}
                width={selectedPhoto.width}
                height={selectedPhoto.height}
                class="photo-main-image h-full w-full object-cover"
              />
            </div>
          ) : (
            <div id="photo-media-image" class="absolute inset-0 z-0">
              <Image src={placeholderImage} alt={`Placeholder photograph ${id_of_the_photo}`} class="photo-main-image h-full w-full object-cover" />
            </div>
          )
        }
        <div
          id="photo-media-map"
          class="absolute inset-0 z-10 hidden bg-white"
          data-map-mode={mapMode}
          data-lat={locationLat ?? ''}
          data-lng={locationLon ?? ''}
          data-target-lat={targetLocationLat ?? ''}
          data-target-lng={targetLocationLon ?? ''}
          data-google-api-key={googleMapsApiKey}
          data-henks-icon={henksMarker.src}
          data-target-icon={cameraIcon.src}
        >
          {
            hasInteractiveMap ? (
              <div id="photo-media-map-canvas" class="h-full w-full"></div>
            ) : hasMapMedia ? (
              <>
                <iframe
                  src={mapEmbedUrl ?? undefined}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={location ? `Map for ${location}` : 'Map'}
                  class="map-frame h-full w-full border-0"
                ></iframe>
                <img
                  src={henksMarker.src}
                  alt=""
                  aria-hidden="true"
                  class="pointer-events-none absolute top-1/2 left-1/2 z-10 -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/80 object-cover shadow-sm"
                  style="width: 34px; height: 34px;"
                />
              </>
            ) : (
              <div class="photo-map-empty-state absolute inset-0 z-20 flex items-center justify-center px-6 text-center text-sm text-slate-500">
                <span>Dang! No location available for</span> <span class="ml-2 text-black">"{title}"</span>
              </div>
            )
          }
        </div>
        </div>

        <div id="photo-meta">
          {exposureLine ? <p class="mt-6 text-sm text-stone-600 md:text-base">{exposureLine}</p> : null}
          {
            description ? (
              <div class="mt-6 flex max-w-3xl items-start gap-3 sm:items-center">
                <img
                  src={henksMarker.src}
                  alt=""
                  aria-hidden="true"
                  class="h-7 w-7 shrink-0 rounded-full border border-white/80 object-cover shadow-sm"
                />
                <p class="text-sm leading-relaxed text-slate-500">{description}</p>
              </div>
            ) : null
          }
        </div>
        <div id="photo-map-mobile" class="mt-7 overflow-hidden rounded-sm bg-white md:hidden">
          {
            hasInteractiveMap ? (
              <div
                id="photo-map-mobile-layer"
                class="relative h-65 w-full bg-white"
                data-map-mode={mapMode}
                data-lat={locationLat ?? ''}
                data-lng={locationLon ?? ''}
                data-target-lat={targetLocationLat ?? ''}
                data-target-lng={targetLocationLon ?? ''}
                data-google-api-key={googleMapsApiKey}
                data-henks-icon={henksMarker.src}
                data-target-icon={cameraIcon.src}
              >
                <div id="photo-map-mobile-canvas" class="h-full w-full"></div>
              </div>
            ) : hasMapMedia ? (
              <div class="relative h-65 w-full">
                <iframe
                  src={mapEmbedUrl ?? undefined}
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={location ? `Map for ${location}` : 'Map'}
                  class="map-frame h-full w-full border-0"
                ></iframe>
                <img
                  src={henksMarker.src}
                  alt=""
                  aria-hidden="true"
                  class="pointer-events-none absolute top-1/2 left-1/2 z-10 -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/80 object-cover shadow-sm"
                  style="width: 30px; height: 30px;"
                />
              </div>
            ) : (
              <div class="photo-map-empty-state flex min-h-40 items-center justify-center px-6 py-6 text-center text-sm text-slate-500">
                <span>Dang! No location available for</span> <span class="ml-2 text-black">"{title}"</span>
              </div>
            )
          }
        </div>
        {
          leftLoopId && rightLoopId ? (
            <nav class="photo-mobile-pagination mt-7 flex items-center justify-between gap-3 pt-4 md:hidden" aria-label="Photo pagination">
              <a
                id="photo-nav-left-mobile"
                data-photo-prev
                href={`/photo/${encodeURIComponent(leftLoopId)}`}
                class="photo-mobile-pagination-link nav-focusable leading-none"
                aria-label="Previous photo"
              >
                <span class="icon-mask block h-2.5 w-2.5 self-center bg-current" style={`--icon-url: url('${caretLeft.src}');`}></span>
                <span>Previous</span>
              </a>
              <a
                id="photo-nav-right-mobile"
                data-photo-next
                href={`/photo/${encodeURIComponent(rightLoopId)}`}
                class="photo-mobile-pagination-link nav-focusable leading-none"
                aria-label="Next photo"
              >
                <span>Next</span>
                <span class="icon-mask block h-2.5 w-2.5 self-center bg-current" style={`--icon-url: url('${caretRight.src}');`}></span>
              </a>
            </nav>
          ) : null
        }
        </div>
      </section>
    </div>
  </main>
</Layout>

<noscript>
  <style>
    @media (min-width: 1024px) {
      #photo-page-section.photo-page-section--desktop-loading #photo-media-column {
        opacity: 1 !important;
        visibility: visible !important;
        pointer-events: auto !important;
      }
    }
  </style>
</noscript>

<script is:inline>
  (() => {
    const TARGET_LINE_PIXEL_LENGTH = 200;
    const MARKER_OVERLAP_DISTANCE_PX = 34;
    const photoLayer = document.getElementById('photo-media-image');
    const photoPageSection = document.getElementById('photo-page-section');
    const mapLayer = document.getElementById('photo-media-map');
    const mediaContainer = document.getElementById('photo-media-container');
    const photoMeta = document.getElementById('photo-meta');
    const showPhotoButton = document.getElementById('show-photo-button');
    const showMapButton = document.getElementById('show-map-button');
    const cameraIcon = document.getElementById('camera-icon');
    const locationIcon = document.getElementById('location-icon');
    const leftNavLink = document.getElementById('photo-nav-left');
    const rightNavLink = document.getElementById('photo-nav-right');
    const mobileLeftNavLink = document.getElementById('photo-nav-left-mobile');
    const mobileRightNavLink = document.getElementById('photo-nav-right-mobile');
    const mobileMapLayer = document.getElementById('photo-map-mobile-layer');
    const swipeSurface = document.getElementById('photo-media-container');
    const FULL_QUERY_PARAM = 'full';
    const LEGACY_IMMERSIVE_QUERY_PARAM = 'immersive';
    const MEDIA_QUERY_PARAM = 'media';
    const SCROLL_POSITION_STORAGE_KEY = 'photo-scroll-position-y';
    const MOBILE_MEDIA_QUERY = '(max-width: 767px)';
    const SWIPE_TRIGGER_DISTANCE = 56;
    let currentMediaMode = 'photo';

    if (!photoLayer || !showPhotoButton || !cameraIcon || !locationIcon) return;

    const mainImage = photoLayer.querySelector('.photo-main-image');
    let isMainImageReady = false;
    let isInitialDesktopLayoutReady = false;

    const revealDesktopPhotoContent = () => {
      if (!photoPageSection) return;
      if (!window.matchMedia('(min-width: 1024px)').matches) {
        photoPageSection.classList.remove('photo-page-section--desktop-loading');
        photoPageSection.classList.add('photo-page-section--desktop-ready');
        return;
      }
      if (!isMainImageReady || !isInitialDesktopLayoutReady) return;
      photoPageSection.classList.remove('photo-page-section--desktop-loading');
      photoPageSection.classList.add('photo-page-section--desktop-ready');
    };

    const setMediaContainerReady = () => {
      isMainImageReady = true;
      mediaContainer?.classList.add('photo-media-container--image-ready');
      revealDesktopPhotoContent();
    };

    if (mainImage instanceof HTMLImageElement) {
      if (mainImage.complete && mainImage.naturalWidth > 0) {
        setMediaContainerReady();
      } else {
        mainImage.addEventListener('load', setMediaContainerReady, { once: true });
        mainImage.addEventListener('error', setMediaContainerReady, { once: true });
      }
    }

    const setIconState = (mode) => {
      if (mode === 'map') {
        cameraIcon.classList.remove('control-icon-active');
        cameraIcon.classList.add('control-icon-inactive');
        locationIcon.classList.remove('control-icon-inactive');
        locationIcon.classList.add('control-icon-active');
      } else {
        cameraIcon.classList.remove('control-icon-inactive');
        cameraIcon.classList.add('control-icon-active');
        locationIcon.classList.remove('control-icon-active');
        locationIcon.classList.add('control-icon-inactive');
      }
    };

    const setMediaUrlState = (mode) => {
      const url = new URL(window.location.href);
      if (mode === 'map') {
        url.searchParams.set(MEDIA_QUERY_PARAM, 'map');
      } else {
        url.searchParams.delete(MEDIA_QUERY_PARAM);
      }
      window.history.replaceState({}, '', url);
    };

    const showPhoto = ({ persistUrl = true } = {}) => {
      photoLayer.classList.remove('hidden');
      mapLayer?.classList.add('hidden');
      currentMediaMode = 'photo';
      setIconState('photo');
      if (persistUrl) {
        setMediaUrlState('photo');
      }
    };

    const isFullMode = () => document.documentElement.classList.contains('photo-full');

    const setFullUrlState = (enabled) => {
      const url = new URL(window.location.href);
      if (enabled) {
        url.searchParams.set(FULL_QUERY_PARAM, '1');
      } else {
        url.searchParams.delete(FULL_QUERY_PARAM);
      }
      url.searchParams.delete(LEGACY_IMMERSIVE_QUERY_PARAM);
      window.history.replaceState({}, '', url);
    };

    const navigateToPhotoLink = (link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      try {
        sessionStorage.setItem(SCROLL_POSITION_STORAGE_KEY, String(window.scrollY));
      } catch {
        // Ignore storage failures.
      }
      const url = new URL(link.href, window.location.origin);
      if (isFullMode()) {
        url.searchParams.set(FULL_QUERY_PARAM, '1');
        url.searchParams.delete(LEGACY_IMMERSIVE_QUERY_PARAM);
      } else {
        url.searchParams.delete(FULL_QUERY_PARAM);
        url.searchParams.delete(LEGACY_IMMERSIVE_QUERY_PARAM);
      }
      if (currentMediaMode === 'map') {
        url.searchParams.set(MEDIA_QUERY_PARAM, 'map');
      } else {
        url.searchParams.delete(MEDIA_QUERY_PARAM);
      }
      window.location.href = url.toString();
    };

    const enterFullPhotoMode = () => {
      showPhoto();
      document.documentElement.classList.add('photo-full');
      setFullUrlState(true);
      window.scrollTo({ top: 0, behavior: 'auto' });
    };

    const exitFullPhotoMode = () => {
      document.documentElement.classList.remove('photo-full');
      setFullUrlState(false);
    };

    const showTemporaryZoomLabel = (zoomLevel) => {
      if (!mapLayer) return;
      let zoomLabel = mapLayer.querySelector('[data-map-zoom-label]');
      if (!zoomLabel) {
        zoomLabel = document.createElement('div');
        zoomLabel.setAttribute('data-map-zoom-label', 'true');
        zoomLabel.style.position = 'absolute';
        zoomLabel.style.left = '50%';
        zoomLabel.style.bottom = '16px';
        zoomLabel.style.transform = 'translateX(-50%)';
        zoomLabel.style.padding = '4px 10px';
        zoomLabel.style.borderRadius = '9999px';
        zoomLabel.style.background = 'rgba(17,24,39,0.8)';
        zoomLabel.style.color = '#fff';
        zoomLabel.style.fontSize = '12px';
        zoomLabel.style.lineHeight = '1';
        zoomLabel.style.zIndex = '30';
        zoomLabel.style.pointerEvents = 'none';
        zoomLabel.style.opacity = '0';
        zoomLabel.style.transition = 'opacity 160ms ease';
        mapLayer.appendChild(zoomLabel);
      }

      const roundedZoom = Math.round(zoomLevel * 10) / 10;
      zoomLabel.textContent = `Zoom ${roundedZoom}`;
      zoomLabel.style.opacity = '1';

      if (zoomLabel.__hideTimeoutId) {
        clearTimeout(zoomLabel.__hideTimeoutId);
      }
      zoomLabel.__hideTimeoutId = setTimeout(() => {
        zoomLabel.style.opacity = '0';
      }, 900);
    };

    const loadLeaflet = () => {
      if (window.L && window.L.map) {
        return Promise.resolve(window.L);
      }

      return new Promise((resolve, reject) => {
        const existingScript = document.querySelector('script[data-leaflet-loader]');
        if (existingScript) {
          existingScript.addEventListener(
            'load',
            () => {
              if (window.L && window.L.map) resolve(window.L);
              else reject(new Error('Leaflet loaded without global API'));
            },
            { once: true },
          );
          existingScript.addEventListener('error', () => reject(new Error('Failed to load Leaflet')), { once: true });
          return;
        }

        if (!document.querySelector('link[data-leaflet-style]')) {
          const style = document.createElement('link');
          style.rel = 'stylesheet';
          style.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
          style.dataset.leafletStyle = 'true';
          document.head.appendChild(style);
        }

        const script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.async = true;
        script.defer = true;
        script.dataset.leafletLoader = 'true';
        script.onload = () => {
          if (window.L && window.L.map) resolve(window.L);
          else reject(new Error('Leaflet loaded without global API'));
        };
        script.onerror = () => reject(new Error('Failed to load Leaflet'));
        document.head.appendChild(script);
      });
    };

    const loadGoogleMaps = (apiKey) => {
      if (window.google && window.google.maps) {
        return Promise.resolve();
      }

      return new Promise((resolve, reject) => {
        const existingScript = document.querySelector('script[data-google-maps-loader]');
        if (existingScript) {
          existingScript.addEventListener('load', () => resolve(), { once: true });
          existingScript.addEventListener('error', () => reject(new Error('Failed to load Google Maps')), { once: true });
          return;
        }

        const script = document.createElement('script');
        script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(apiKey)}&v=weekly`;
        script.async = true;
        script.defer = true;
        script.dataset.googleMapsLoader = 'true';
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('Failed to load Google Maps'));
        document.head.appendChild(script);
      });
    };

    const createCameraOverlayHtml = (markerUrl) => `
      <div class="camera-overlay" style="position: relative; width: 34px; height: 34px; pointer-events: none;">
        <img
          src="${markerUrl}"
          alt=""
          aria-hidden="true"
          class="camera-overlay__marker"
          style="position: absolute; left: 50%; top: 50%; width: 34px; height: 34px; transform: translate(-50%, -50%); z-index: 2; object-fit: cover; border-radius: 9999px; border: 1px solid rgba(255,255,255,0.8); box-shadow: 0 1px 2px rgba(0,0,0,0.15);"
        />
      </div>
    `;

    const createTargetOverlayHtml = (iconUrl) => `
      <div
        style="position: relative; width: 26px; height: 26px; pointer-events: none; border-radius: 9999px; background: #ffffff; border: 1px solid rgba(0,0,0,0.1); box-shadow: 0 1px 2px rgba(0,0,0,0.18);"
      >
        <img
          src="${iconUrl}"
          alt=""
          aria-hidden="true"
          style="position: absolute; left: 50%; top: 50%; width: 14px; height: 14px; transform: translate(-50%, -50%); object-fit: contain;"
        />
      </div>
    `;

    const initGoogleMap = async ({ lat, lng, targetLat, targetLng, canvas, apiKey, henksIcon, targetIcon }) => {
      await loadGoogleMaps(apiKey);

      const center = { lat, lng };
      const hasTargetLocation = Number.isFinite(targetLat) && Number.isFinite(targetLng);
      const targetsCenter = hasTargetLocation
        ? { lat: (lat + targetLat) / 2, lng: (lng + targetLng) / 2 }
        : center;
      const map = new google.maps.Map(canvas, {
        center,
        zoom: 16,
        disableDefaultUI: false,
        zoomControl: true,
        zoomControlOptions: {
          position: google.maps.ControlPosition.RIGHT_BOTTOM,
        },
        mapTypeControl: false,
        scaleControl: true,
        streetViewControl: false,
        fullscreenControl: false,
        styles: [
          { featureType: 'all', elementType: 'labels', stylers: [{ visibility: 'off' }] },
          { featureType: 'road.arterial', elementType: 'labels.text', stylers: [{ visibility: 'on' }] },
          { featureType: 'road.highway', elementType: 'labels.text', stylers: [{ visibility: 'on' }] },
          { featureType: 'administrative.locality', elementType: 'labels.text', stylers: [{ visibility: 'on' }] },
          { featureType: 'poi', stylers: [{ visibility: 'off' }] },
          { featureType: 'transit', stylers: [{ visibility: 'off' }] },
          { featureType: 'administrative', elementType: 'labels.text.stroke', stylers: [{ visibility: 'off' }] },
          { featureType: 'all', stylers: [{ saturation: -100 }, { lightness: 8 }] },
        ],
      });

      let connectionLine = null;
      if (hasTargetLocation) {
        const target = { lat: targetLat, lng: targetLng };
        const bounds = new google.maps.LatLngBounds();
        bounds.extend(center);
        bounds.extend(target);
        map.fitBounds(bounds, 24);
        google.maps.event.addListenerOnce(map, 'idle', () => {
          const projection = map.getProjection();
          if (!projection) return;

          const pointA = projection.fromLatLngToPoint(new google.maps.LatLng(center.lat, center.lng));
          const pointB = projection.fromLatLngToPoint(new google.maps.LatLng(target.lat, target.lng));
          const worldDistance = Math.hypot(pointA.x - pointB.x, pointA.y - pointB.y);
          if (!Number.isFinite(worldDistance) || worldDistance <= 0) return;

          const desiredZoom = Math.log2(TARGET_LINE_PIXEL_LENGTH / worldDistance);
          const clampedZoom = Math.max(2, Math.min(21, desiredZoom));
          map.setZoom(clampedZoom);
        });

        const baseLineColor = '#111827';
        connectionLine = new google.maps.Polyline({
          path: [center, target],
          map,
          geodesic: true,
          strokeColor: baseLineColor,
          strokeOpacity: 0,
          strokeWeight: 2,
          zIndex: 1,
          clickable: false,
          icons: [
            {
              icon: {
                path: 'M 0,-1 0,1',
                strokeOpacity: 0.7,
                strokeColor: baseLineColor,
                scale: 2,
              },
              offset: '0',
              repeat: '10px',
            },
          ],
        });
      }

      class HtmlOverlay extends google.maps.OverlayView {
        constructor(position, html) {
          super();
          this.position = position;
          this.html = html;
          this.container = null;
          this.visible = true;
        }

        onAdd() {
          const div = document.createElement('div');
          div.style.position = 'absolute';
          div.style.transform = 'translate(-50%, -50%)';
          div.style.pointerEvents = 'none';
          div.style.zIndex = '10';
          div.innerHTML = this.html;
          this.container = div;
          this.getPanes().overlayMouseTarget.appendChild(div);
          this.container.style.display = this.visible ? 'block' : 'none';
        }

        draw() {
          if (!this.container) return;
          const projection = this.getProjection();
          if (!projection) return;
          const point = projection.fromLatLngToDivPixel(this.position);
          if (!point) return;
          this.container.style.left = `${point.x}px`;
          this.container.style.top = `${point.y}px`;
        }

        setVisible(isVisible) {
          this.visible = isVisible;
          if (this.container) {
            this.container.style.display = isVisible ? 'block' : 'none';
          }
        }

        onRemove() {
          if (this.container && this.container.parentNode) {
            this.container.parentNode.removeChild(this.container);
          }
          this.container = null;
        }
      }

      const mainOverlay = new HtmlOverlay(center, createCameraOverlayHtml(henksIcon));
      mainOverlay.setMap(map);
      let targetOverlay = null;

      const updateMapDetailVisibility = () => {
        const currentZoom = map.getZoom() ?? 0;
        let shouldShowTarget = true;
        if (targetOverlay) {
          const projection = map.getProjection();
          if (projection) {
            const pointA = projection.fromLatLngToPoint(new google.maps.LatLng(center.lat, center.lng));
            const pointB = projection.fromLatLngToPoint(new google.maps.LatLng(targetLat, targetLng));
            const pixelDistance = Math.hypot(pointA.x - pointB.x, pointA.y - pointB.y) * Math.pow(2, currentZoom);
            shouldShowTarget = pixelDistance > MARKER_OVERLAP_DISTANCE_PX;
          }
        }
        mainOverlay.setVisible(true);
        if (targetOverlay) {
          targetOverlay.setVisible(shouldShowTarget);
        }
        if (connectionLine) {
          connectionLine.setVisible(shouldShowTarget);
        }
        if (hasTargetLocation) {
          map.setCenter(targetsCenter);
        }
        showTemporaryZoomLabel(currentZoom);
      };
      updateMapDetailVisibility();
      map.addListener('zoom_changed', updateMapDetailVisibility);

      if (hasTargetLocation && targetIcon) {
        const target = { lat: targetLat, lng: targetLng };
        targetOverlay = new HtmlOverlay(target, createTargetOverlayHtml(targetIcon));
        targetOverlay.setMap(map);
        updateMapDetailVisibility();
      }

      return {
        provider: 'google',
        resize: () => {
          google.maps.event.trigger(map, 'resize');
          if (hasTargetLocation) {
            map.setCenter(targetsCenter);
          } else {
            map.setCenter(center);
          }
          updateMapDetailVisibility();
        },
      };
    };

    const initLeafletMap = async ({ lat, lng, targetLat, targetLng, canvas, henksIcon, targetIcon }) => {
      const L = await loadLeaflet();
      const center = [lat, lng];
      const hasTargetLocation = Number.isFinite(targetLat) && Number.isFinite(targetLng);
      const targetsCenter = hasTargetLocation
        ? L.latLng((lat + targetLat) / 2, (lng + targetLng) / 2)
        : L.latLng(lat, lng);
      const map = L.map(canvas, {
        zoomControl: true,
        attributionControl: true,
        zoomSnap: 0.1,
      });
      if (hasTargetLocation) {
        map.fitBounds(
          [
            center,
            [targetLat, targetLng],
          ],
          { padding: [24, 24], maxZoom: 19 },
        );
        map.once('moveend', () => {
          const currentZoom = map.getZoom();
          const pointA = map.project(center, currentZoom);
          const pointB = map.project([targetLat, targetLng], currentZoom);
          const pixelDistance = pointA.distanceTo(pointB);
          if (!Number.isFinite(pixelDistance) || pixelDistance <= 0) return;

          const desiredZoom = currentZoom + Math.log2(TARGET_LINE_PIXEL_LENGTH / pixelDistance);
          const clampedZoom = Math.max(2, Math.min(19, desiredZoom));
          map.setZoom(clampedZoom, { animate: false });
        });
      } else {
        map.setView(center, 16);
      }

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; OpenStreetMap contributors',
      }).addTo(map);

      let connectionLine = null;
      if (hasTargetLocation) {
        connectionLine = L.polyline([center, [targetLat, targetLng]], {
          color: '#111827',
          weight: 2,
          opacity: 0.7,
          dashArray: '6 6',
          interactive: false,
        }).addTo(map);
      }

      const cameraOverlayIcon = L.divIcon({
        className: 'camera-overlay-wrapper',
        html: createCameraOverlayHtml(henksIcon),
        iconSize: [34, 34],
        iconAnchor: [17, 17],
      });
      const cameraMarker = L.marker(center, { icon: cameraOverlayIcon, interactive: false }).addTo(map);

      const updateMapDetailVisibility = () => {
        const currentZoom = map.getZoom();
        let shouldShowTarget = true;
        if (hasTargetLocation) {
          const pointA = map.project(center, currentZoom);
          const pointB = map.project([targetLat, targetLng], currentZoom);
          const pixelDistance = pointA.distanceTo(pointB);
          shouldShowTarget = pixelDistance > MARKER_OVERLAP_DISTANCE_PX;
        }
        cameraMarker.setOpacity(1);
        if (hasTargetLocation) {
          targetMarker.setOpacity(shouldShowTarget ? 1 : 0);
        }
        if (connectionLine) {
          connectionLine.setStyle({ opacity: shouldShowTarget ? 0.7 : 0 });
        }
        if (hasTargetLocation) {
          map.panTo(targetsCenter, { animate: false });
        }
        showTemporaryZoomLabel(currentZoom);
      };
      let targetMarker = null;
      if (hasTargetLocation) {
        const targetOverlayIcon = L.divIcon({
          className: 'target-overlay-wrapper',
          html: createTargetOverlayHtml(targetIcon),
          iconSize: [26, 26],
          iconAnchor: [13, 13],
        });
        targetMarker = L.marker([targetLat, targetLng], {
          icon: targetOverlayIcon,
          interactive: false,
        }).addTo(map);
      }
      updateMapDetailVisibility();
      map.on('zoomend', updateMapDetailVisibility);

      setTimeout(() => {
        map.invalidateSize();
      }, 0);

      return {
        provider: 'leaflet',
        resize: () => {
          map.invalidateSize();
          if (hasTargetLocation) {
            map.panTo(targetsCenter, { animate: false });
          } else {
            map.panTo(center, { animate: false });
          }
          updateMapDetailVisibility();
        },
      };
    };

    const initInteractiveMap = async (layer = mapLayer, canvasId = 'photo-media-map-canvas') => {
      if (!layer || layer.dataset.mapMode !== 'interactive') return null;
      if (layer.dataset.initialized === 'true' && layer.__mapController) {
        return layer.__mapController;
      }

      const toFiniteCoordinate = (value) => {
        if (value === undefined || value === null || value === '') return null;
        const parsed = Number(value);
        return Number.isFinite(parsed) ? parsed : null;
      };

      const lat = toFiniteCoordinate(layer.dataset.lat);
      const lng = toFiniteCoordinate(layer.dataset.lng);
      const targetLat = toFiniteCoordinate(layer.dataset.targetLat);
      const targetLng = toFiniteCoordinate(layer.dataset.targetLng);
      const googleApiKey = layer.dataset.googleApiKey || '';
      const henksIcon = layer.dataset.henksIcon;
      const targetIcon = layer.dataset.targetIcon;
      const canvas = document.getElementById(canvasId);

      if (!Number.isFinite(lat) || !Number.isFinite(lng) || !canvas || !henksIcon || !targetIcon) return;
      const mapConfig = { lat, lng, targetLat, targetLng, henksIcon, targetIcon, canvas };
      try {
        let mapController = null;
        if (googleApiKey) {
          mapController = await initGoogleMap({ ...mapConfig, apiKey: googleApiKey });
        } else {
          console.warn('[photo-map] GOOGLE_MAPS_API_KEY is missing. Falling back to Leaflet.');
          mapController = await initLeafletMap(mapConfig);
        }
        layer.__mapController = mapController;
        layer.dataset.initialized = 'true';
        return mapController;
      } catch (error) {
        if (googleApiKey) {
          console.warn('[photo-map] Google Maps failed to initialize. Falling back to Leaflet.', error);
          const mapController = await initLeafletMap(mapConfig);
          layer.__mapController = mapController;
          layer.dataset.initialized = 'true';
          return mapController;
        } else {
          throw error;
        }
      }
    };

    const refreshInteractiveMapLayout = (layer = mapLayer) => {
      if (!layer) return;
      const mapController = layer.__mapController;
      if (mapController && typeof mapController.resize === 'function') {
        mapController.resize();
      }
    };

    const showMap = async ({ persistUrl = true } = {}) => {
      if (!mapLayer) return;
      photoLayer.classList.add('hidden');
      mapLayer.classList.remove('hidden');
      currentMediaMode = 'map';
      setIconState('map');
      if (persistUrl) {
        setMediaUrlState('map');
      }
      await initInteractiveMap(mapLayer, 'photo-media-map-canvas');
      refreshInteractiveMapLayout(mapLayer);
    };

    const syncMetaWidthToMedia = () => {
      if (!mediaContainer || !photoMeta) return;
      if (!window.matchMedia('(min-width: 768px)').matches) {
        photoMeta.style.removeProperty('max-width');
        return;
      }

      const mediaWidth = mediaContainer.getBoundingClientRect().width;
      if (mediaWidth > 0) {
        photoMeta.style.maxWidth = `${Math.round(mediaWidth)}px`;
      }
    };

    const syncMediaHeightToViewport = () => {
      if (!mediaContainer) return;
      if (isFullMode()) {
        mediaContainer.style.removeProperty('--media-fit-height');
        return;
      }
      if (!window.matchMedia('(min-width: 768px)').matches) {
        mediaContainer.style.removeProperty('--media-fit-height');
        return;
      }

      const topOffset = mediaContainer.getBoundingClientRect().top;
      const viewportHeight = window.innerHeight;
      const hasMetaContent = Boolean(photoMeta && photoMeta.textContent?.trim());
      const metaHeight = hasMetaContent && photoMeta ? photoMeta.getBoundingClientRect().height : 0;
      const metaSpacing = hasMetaContent ? 28 : 0;
      const footerBuffer = window.matchMedia('(min-width: 1024px)').matches ? 34 : 22;
      const availableHeight = Math.floor(viewportHeight - topOffset - metaHeight - metaSpacing - footerBuffer);
      const aspectRatio = Number(mediaContainer.dataset.aspectRatio);
      const columnWidth = Math.floor(
        mediaContainer.parentElement?.getBoundingClientRect().width ?? mediaContainer.getBoundingClientRect().width,
      );
      const maxHeightByWidth =
        Number.isFinite(aspectRatio) && aspectRatio > 0 && columnWidth > 0 ? Math.floor(columnWidth / aspectRatio) : availableHeight;
      const fittedHeight = Math.min(availableHeight, maxHeightByWidth);

      if (fittedHeight > 220) {
        mediaContainer.style.setProperty('--media-fit-height', `${fittedHeight}px`);
      } else {
        mediaContainer.style.removeProperty('--media-fit-height');
      }
    };

    const getPrevNavLink = () => {
      if (leftNavLink instanceof HTMLAnchorElement) return leftNavLink;
      if (mobileLeftNavLink instanceof HTMLAnchorElement) return mobileLeftNavLink;
      return null;
    };

    const getNextNavLink = () => {
      if (rightNavLink instanceof HTMLAnchorElement) return rightNavLink;
      if (mobileRightNavLink instanceof HTMLAnchorElement) return mobileRightNavLink;
      return null;
    };

    const handleNavClick = (event, link) => {
      event.preventDefault();
      navigateToPhotoLink(link);
    };

    showPhotoButton.addEventListener('click', showPhoto);
    showMapButton?.addEventListener('click', () => {
      void showMap();
    });
    if (leftNavLink instanceof HTMLAnchorElement) {
      leftNavLink.addEventListener('click', (event) => handleNavClick(event, leftNavLink));
    }
    if (rightNavLink instanceof HTMLAnchorElement) {
      rightNavLink.addEventListener('click', (event) => handleNavClick(event, rightNavLink));
    }
    if (mobileLeftNavLink instanceof HTMLAnchorElement) {
      mobileLeftNavLink.addEventListener('click', (event) => handleNavClick(event, mobileLeftNavLink));
    }
    if (mobileRightNavLink instanceof HTMLAnchorElement) {
      mobileRightNavLink.addEventListener('click', (event) => handleNavClick(event, mobileRightNavLink));
    }

    document.addEventListener('keydown', (event) => {
      if (event.defaultPrevented || event.altKey || event.ctrlKey || event.metaKey || event.shiftKey) return;

      const activeElement = document.activeElement;
      if (
        activeElement &&
        (activeElement.tagName === 'INPUT' ||
          activeElement.tagName === 'TEXTAREA' ||
          activeElement.tagName === 'SELECT' ||
          activeElement.isContentEditable)
      ) {
        return;
      }

      if (event.key === 'Escape') {
        event.preventDefault();
        exitFullPhotoMode();
        window.location.href = '/';
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        enterFullPhotoMode();
      } else if (event.key === 'ArrowDown') {
        event.preventDefault();
        if (document.documentElement.classList.contains('photo-full')) {
          exitFullPhotoMode();
        } else {
          window.location.href = '/';
        }
      } else if (event.key === 'ArrowLeft' && getPrevNavLink() instanceof HTMLAnchorElement) {
        const prevLink = getPrevNavLink();
        event.preventDefault();
        if (prevLink instanceof HTMLAnchorElement) {
          navigateToPhotoLink(prevLink);
        }
      } else if (event.key === 'ArrowRight' && getNextNavLink() instanceof HTMLAnchorElement) {
        const nextLink = getNextNavLink();
        event.preventDefault();
        if (nextLink instanceof HTMLAnchorElement) {
          navigateToPhotoLink(nextLink);
        }
      }
    });

    const initialSearchParams = new URLSearchParams(window.location.search);
    const isMobileView = window.matchMedia(MOBILE_MEDIA_QUERY).matches;
    if (!isMobileView && initialSearchParams.get(MEDIA_QUERY_PARAM) === 'map' && mapLayer) {
      void showMap({ persistUrl: false });
    } else {
      showPhoto({ persistUrl: false });
    }
    if (isMobileView && mobileMapLayer) {
      void initInteractiveMap(mobileMapLayer, 'photo-map-mobile-canvas');
    }

    if (initialSearchParams.get(FULL_QUERY_PARAM) === '1' || initialSearchParams.get(LEGACY_IMMERSIVE_QUERY_PARAM) === '1') {
      enterFullPhotoMode();
    }

    if (initialSearchParams.get(FULL_QUERY_PARAM) !== '1' && initialSearchParams.get(LEGACY_IMMERSIVE_QUERY_PARAM) !== '1') {
      try {
        const storedScrollY = sessionStorage.getItem(SCROLL_POSITION_STORAGE_KEY);
        if (storedScrollY !== null) {
          sessionStorage.removeItem(SCROLL_POSITION_STORAGE_KEY);
          const scrollY = Number(storedScrollY);
          if (Number.isFinite(scrollY) && scrollY > 0) {
            window.scrollTo({ top: scrollY, behavior: 'auto' });
          }
        }
      } catch {
        // Ignore storage failures.
      }
    }

    const syncDesktopLayout = () => {
      syncMetaWidthToMedia();
      syncMediaHeightToViewport();
      refreshInteractiveMapLayout(mapLayer);
      refreshInteractiveMapLayout(mobileMapLayer);
    };

    let resizeRafId = 0;
    const scheduleLayoutSync = () => {
      if (resizeRafId) {
        cancelAnimationFrame(resizeRafId);
      }
      resizeRafId = requestAnimationFrame(() => {
        resizeRafId = 0;
        syncDesktopLayout();
      });
    };

    syncDesktopLayout();
    requestAnimationFrame(() => {
      isInitialDesktopLayoutReady = true;
      revealDesktopPhotoContent();
    });
    window.addEventListener('resize', scheduleLayoutSync);

    if (typeof ResizeObserver !== 'undefined' && mediaContainer) {
      const layoutObserver = new ResizeObserver(() => {
        scheduleLayoutSync();
      });
      layoutObserver.observe(mediaContainer);
    }

    if (swipeSurface) {
      let pointerStartX = 0;
      let pointerStartY = 0;
      let swipeInProgress = false;

      swipeSurface.addEventListener(
        'touchstart',
        (event) => {
          if (!window.matchMedia(MOBILE_MEDIA_QUERY).matches) return;
          if (event.touches.length !== 1) return;
          const touch = event.touches[0];
          pointerStartX = touch.clientX;
          pointerStartY = touch.clientY;
          swipeInProgress = true;
        },
        { passive: true },
      );

      swipeSurface.addEventListener(
        'touchend',
        (event) => {
          if (!swipeInProgress || !window.matchMedia(MOBILE_MEDIA_QUERY).matches) return;
          const touch = event.changedTouches[0];
          if (!touch) return;
          const deltaX = touch.clientX - pointerStartX;
          const deltaY = touch.clientY - pointerStartY;
          swipeInProgress = false;

          if (Math.abs(deltaX) < SWIPE_TRIGGER_DISTANCE || Math.abs(deltaY) > Math.abs(deltaX) * 0.8) {
            return;
          }
          if (deltaX > 0) {
            const prevLink = getPrevNavLink();
            if (prevLink instanceof HTMLAnchorElement) navigateToPhotoLink(prevLink);
          } else {
            const nextLink = getNextNavLink();
            if (nextLink instanceof HTMLAnchorElement) navigateToPhotoLink(nextLink);
          }
        },
        { passive: true },
      );
    }
  })();
</script>

