---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Folks | Henks Photography" description="People and portraits by Henrik Löthman.">
  <main class="w-full p-4 sm:p-10 lg:p-12">
    <div class="lg:grid desktop-layout-grid lg:grid-cols-[minmax(180px,16%)_minmax(0,1fr)] lg:gap-x-12">
      <Nav activeTab="folks" />
      <section class="pt-16 lg:pt-0">
        <h1 class="text-3xl font-medium text-stone-700">Folks</h1>
        <p class="mt-4 text-base text-stone-500">Portrait work and stories are coming soon.</p>
      </section>
    </div>
  </main>
</Layout>
