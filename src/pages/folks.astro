---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Folks | Henks Photography" description="People and portraits by Henrik Löthman.">
  <main class="mx-auto max-w-7xl px-6 pb-20 pt-17">
    <Nav activeTab="folks" />
    <section class="pt-16">
      <h1 class="text-3xl font-medium text-stone-700">Folks</h1>
      <p class="mt-4 text-base text-stone-500">Portrait work and stories are coming soon.</p>
    </section>
  </main>
</Layout>
