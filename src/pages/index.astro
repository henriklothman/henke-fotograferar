---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import MasonryImage from '../components/MasonryImage.astro';
import placeholderImage from '../assets/placeholder-image.svg';
import { getContentfulPhotos } from '../lib/contentful';

const masonryBackgrounds = ['bg-slate-100 dark:bg-slate-800', 'bg-slate-200 dark:bg-slate-700', 'bg-slate-300 dark:bg-slate-600'];

function pickSeededBackground(seed: string): string {
  let hash = 0;
  for (let i = 0; i < seed.length; i += 1) {
    hash = (hash << 5) - hash + seed.charCodeAt(i);
    hash |= 0;
  }
  return masonryBackgrounds[Math.abs(hash) % masonryBackgrounds.length];
}

const fallbackItems = [
  { id: 'photo-1', title: 'Placeholder photograph 1', aspect: '3 / 4', alt: 'Placeholder photograph 1', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-1') },
  { id: 'photo-2', title: 'Placeholder photograph 2', aspect: '4 / 3', alt: 'Placeholder photograph 2', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-2') },
  { id: 'photo-3', title: 'Placeholder photograph 3', aspect: '1 / 1', alt: 'Placeholder photograph 3', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-3') },
  { id: 'photo-4', title: 'Placeholder photograph 4', aspect: '2 / 3', alt: 'Placeholder photograph 4', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-4') },
  { id: 'photo-5', title: 'Placeholder photograph 5', aspect: '3 / 2', alt: 'Placeholder photograph 5', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-5') },
  { id: 'photo-6', title: 'Placeholder photograph 6', aspect: '4 / 5', alt: 'Placeholder photograph 6', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-6') },
  { id: 'photo-7', title: 'Placeholder photograph 7', aspect: '5 / 4', alt: 'Placeholder photograph 7', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-7') },
  { id: 'photo-8', title: 'Placeholder photograph 8', aspect: '3 / 5', alt: 'Placeholder photograph 8', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-8') },
  { id: 'photo-9', title: 'Placeholder photograph 9', aspect: '16 / 10', alt: 'Placeholder photograph 9', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-9') },
];

const contentfulPhotos = await getContentfulPhotos();

const masonryItems =
  contentfulPhotos.length > 0
    ? contentfulPhotos.map((photo) => ({
        id: photo.id,
        title: photo.title,
        aspect: `${photo.width} / ${photo.height}`,
        alt: photo.alt,
        src: photo.imageUrl,
        width: photo.width,
        height: photo.height,
        bgClass: pickSeededBackground(photo.id),
      }))
    : fallbackItems;
---

<Layout title="Henks Photography" description="Selected work from the Henks layout.">
  <main class="mx-auto max-w-7xl px-6 pb-20 pt-17">
    <Nav activeTab="photography" />

    <section class="pt-12">
      <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
        {
          masonryItems.map((item) => (
            <MasonryImage
              src={item.src}
              alt={item.alt}
              title={item.title}
              aspect={item.aspect}
              width={item.width}
              height={item.height}
              bgClass={item.bgClass}
              href={`/photo/${encodeURIComponent(item.id)}`}
              className="mb-4 break-inside-avoid"
            />
          ))
        }
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  (() => {
    const ARROW_UP_TOAST_SEEN_KEY = 'index-arrowup-toast-seen-v3';

    const showArrowUpToastOnce = () => {
      try {
        if (localStorage.getItem(ARROW_UP_TOAST_SEEN_KEY) === '1') return;
      } catch {
        // Ignore storage failures and still show toast.
      }

      const toast = document.createElement('div');
      toast.className = 'index-toast';
      toast.setAttribute('role', 'status');
      toast.setAttribute('aria-live', 'polite');
      toast.textContent = 'Arrow up to dive in';
      document.body.appendChild(toast);

      requestAnimationFrame(() => {
        toast.classList.add('is-visible');
      });

      setTimeout(() => {
        toast.classList.remove('is-visible');
        setTimeout(() => {
          toast.remove();
          try {
            localStorage.setItem(ARROW_UP_TOAST_SEEN_KEY, '1');
          } catch {
            // Ignore storage failures.
          }
        }, 240);
      }, 3200);
    };

    const initIndexShortcutsAndToast = () => {
      showArrowUpToastOnce();

      document.addEventListener('keydown', (event) => {
        if (event.defaultPrevented || event.altKey || event.ctrlKey || event.metaKey || event.shiftKey) return;

        const activeElement = document.activeElement;
        if (
          activeElement &&
          (activeElement.tagName === 'INPUT' ||
            activeElement.tagName === 'TEXTAREA' ||
            activeElement.tagName === 'SELECT' ||
            activeElement.isContentEditable)
        ) {
          return;
        }

        if (event.key !== 'ArrowUp') return;
        const firstMasonryLink = document.querySelector('.masonry-link');
        if (!(firstMasonryLink instanceof HTMLAnchorElement)) return;
        event.preventDefault();
        window.location.href = firstMasonryLink.href;
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initIndexShortcutsAndToast, { once: true });
    } else {
      initIndexShortcutsAndToast();
    }
  })();
</script>

<style>
  .index-toast {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 60;
    border-radius: 9999px;
    background: rgba(17, 24, 39, 0.9);
    color: #fff;
    padding: 0.55rem 0.9rem;
    font-size: 0.8rem;
    line-height: 1;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 220ms ease, transform 220ms ease;
    pointer-events: none;
  }

  .index-toast.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
