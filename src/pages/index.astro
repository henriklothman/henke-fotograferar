---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import MasonryImage from '../components/MasonryImage.astro';
import placeholderImage from '../assets/placeholder-image.svg';
import { getContentfulPhotos } from '../lib/contentful';

const masonryBackgrounds = ['bg-slate-100 dark:bg-slate-800', 'bg-slate-200 dark:bg-slate-700', 'bg-slate-300 dark:bg-slate-600'];

function pickSeededBackground(seed: string): string {
  let hash = 0;
  for (let i = 0; i < seed.length; i += 1) {
    hash = (hash << 5) - hash + seed.charCodeAt(i);
    hash |= 0;
  }
  return masonryBackgrounds[Math.abs(hash) % masonryBackgrounds.length];
}

const fallbackItems = [
  { id: 'photo-1', title: 'Placeholder photograph 1', aspect: '3 / 4', alt: 'Placeholder photograph 1', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-1') },
  { id: 'photo-2', title: 'Placeholder photograph 2', aspect: '4 / 3', alt: 'Placeholder photograph 2', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-2') },
  { id: 'photo-3', title: 'Placeholder photograph 3', aspect: '1 / 1', alt: 'Placeholder photograph 3', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-3') },
  { id: 'photo-4', title: 'Placeholder photograph 4', aspect: '2 / 3', alt: 'Placeholder photograph 4', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-4') },
  { id: 'photo-5', title: 'Placeholder photograph 5', aspect: '3 / 2', alt: 'Placeholder photograph 5', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-5') },
  { id: 'photo-6', title: 'Placeholder photograph 6', aspect: '4 / 5', alt: 'Placeholder photograph 6', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-6') },
  { id: 'photo-7', title: 'Placeholder photograph 7', aspect: '5 / 4', alt: 'Placeholder photograph 7', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-7') },
  { id: 'photo-8', title: 'Placeholder photograph 8', aspect: '3 / 5', alt: 'Placeholder photograph 8', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-8') },
  { id: 'photo-9', title: 'Placeholder photograph 9', aspect: '16 / 10', alt: 'Placeholder photograph 9', src: placeholderImage, width: 1200, height: 900, bgClass: pickSeededBackground('photo-9') },
];

const contentfulPhotos = await getContentfulPhotos();

const masonryItems =
  contentfulPhotos.length > 0
    ? contentfulPhotos.map((photo) => ({
        id: photo.id,
        title: photo.title,
        aspect: `${photo.width} / ${photo.height}`,
        alt: photo.alt,
        src: photo.imageUrl,
        width: photo.width,
        height: photo.height,
        bgClass: pickSeededBackground(photo.id),
      }))
    : fallbackItems;

if (contentfulPhotos.length === 0) {
  console.warn('Using placeholder images - Contentful fetch returned no photos');
} else {
  console.log(`Loaded ${contentfulPhotos.length} photos from Contentful`);
}
---

<Layout title="hnrik.com" description="Hobby photography & other stuff by Henrik Löthman">
  <main class="w-full p-4 sm:p-10 lg:p-12">
    <div class="lg:grid lg:grid-cols-[minmax(180px,16%)_minmax(0,1fr)] lg:gap-x-12">
      <Nav activeTab="photography" />

      <section class="pt-4 sm:pt-8 lg:pt-0">
        <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
          {
            masonryItems.map((item) => (
              <MasonryImage
                src={item.src}
                alt={item.alt}
                title={item.title}
                aspect={item.aspect}
                width={item.width}
                height={item.height}
                bgClass={item.bgClass}
                href={`/photo/${encodeURIComponent(item.id)}`}
                className="mb-4 break-inside-avoid"
              />
            ))
          }
        </div>
      </section>
    </div>
    <aside id="index-toast" class="index-toast" role="status" aria-live="polite">
      <button id="index-toast-dismiss" type="button" class="index-toast__dismiss" aria-label="Dismiss keyboard navigation hint">×</button>
      <p class="index-toast__title">Keyboard navigation</p>
      <p><kbd>↑</kbd> Zoom in / fullscreen</p>
      <p><kbd>←</kbd> Previous image</p>
      <p><kbd>→</kbd> Next image</p>
      <p><kbd>↓</kbd> Zoom out / exit</p>
    </aside>
  </main>
</Layout>

<script is:inline>
  (() => {
    const TOAST_DISMISSED_KEY = 'index-keyboard-toast-dismissed-v1';

    const initIndexShortcutsAndToast = () => {
      const toast = document.getElementById('index-toast');
      const dismissButton = document.getElementById('index-toast-dismiss');
      const isDesktop = window.matchMedia('(min-width: 768px)').matches;
      let isDismissed = false;

      try {
        isDismissed = localStorage.getItem(TOAST_DISMISSED_KEY) === '1';
      } catch {
        isDismissed = false;
      }

      if (!isDesktop || isDismissed) {
        toast?.remove();
      } else {
        toast?.classList.add('is-visible');
        dismissButton?.addEventListener('click', () => {
          try {
            localStorage.setItem(TOAST_DISMISSED_KEY, '1');
          } catch {
            // Ignore storage failures.
          }
          toast?.remove();
        });
      }

      document.addEventListener('keydown', (event) => {
        if (event.defaultPrevented || event.altKey || event.ctrlKey || event.metaKey || event.shiftKey) return;
        if (window.location.pathname !== '/') return;

        const activeElement = document.activeElement;
        if (
          activeElement &&
          (activeElement.tagName === 'INPUT' ||
            activeElement.tagName === 'TEXTAREA' ||
            activeElement.tagName === 'SELECT' ||
            activeElement.isContentEditable)
        ) {
          return;
        }

        const masonryLinks = document.querySelectorAll('.masonry-link');
        if (!masonryLinks.length) return;
        const firstMasonryLink = masonryLinks[0];
        const lastMasonryLink = masonryLinks[masonryLinks.length - 1];
        if (!(firstMasonryLink instanceof HTMLAnchorElement) || !(lastMasonryLink instanceof HTMLAnchorElement)) return;

        if (event.key === 'ArrowUp' || event.key === 'ArrowRight') {
          event.preventDefault();
          window.location.href = firstMasonryLink.href;
          return;
        }

        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          window.location.href = lastMasonryLink.href;
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initIndexShortcutsAndToast, { once: true });
    } else {
      initIndexShortcutsAndToast();
    }
  })();
</script>

<style>
  .index-toast {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 60;
    border-radius: 12px;
    background: rgba(17, 24, 39, 0.9);
    color: #fff;
    padding: 0.75rem 0.9rem;
    font-size: 0.78rem;
    line-height: 1.3;
    min-width: 220px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 220ms ease, transform 220ms ease;
    pointer-events: auto;
  }

  .index-toast__dismiss {
    position: absolute;
    top: 0.28rem;
    right: 0.4rem;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.1rem 0.2rem;
  }

  .index-toast p {
    margin: 0;
  }

  .index-toast p + p {
    margin-top: 0.28rem;
  }

  .index-toast__title {
    font-weight: 600;
    letter-spacing: 0.01em;
    margin-bottom: 0.28rem;
  }

  .index-toast kbd {
    display: inline-flex;
    min-width: 1.2rem;
    justify-content: center;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.06);
    padding: 0.02rem 0.2rem;
    font-size: 0.74rem;
    line-height: 1.2;
    margin-right: 0.25rem;
    font-family: inherit;
  }

  .index-toast.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
