---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="About | Henks Photography" description="About Henrik Löthman and this photography portfolio.">
  <main class="mx-auto max-w-[1280px] px-6 pb-20 pt-[69px]">
    <Nav activeTab="about" />
    <section class="pt-16">
      <h1 class="text-3xl font-medium text-stone-700">About</h1>
      <p class="mt-4 text-base text-stone-500">More about Henrik and the work will be added soon.</p>
    </section>
  </main>
</Layout>
