---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const timeline = [
  {
    placement: 'Lyftio.com',
    date: 'apr 2025 → Present',
    title: 'Founder & Front-End Product Developer',
    description: 'Built and launched a SaaS experimentation platform with a strong focus on usability, performance, and AI-powered conversion optimization.',
    bullets: ['Designed and developed modern, responsive user interfaces using SolidJS, Astro, and CSS.', 'Built reusable UI components and scalable front-end architecture', 'Built and maintained a scalable UI library in Figma, including reusable components, design tokens, and consistent interaction patterns', 'Translated UX concepts into high-performing production-ready interfaces', 'Developed features for A/B testing, experiment management, and results visualization', 'Focused on performance, fast load times, and intuitive user flows', 'Worked closely with CRO methodologies to ensure designs drive measurable impact'],
  },
  {
    placement: 'Symplify.com',
    date: 'sep 2021 → apr 2025',
    title: 'Front-End Developer',
    description: 'Built and maintained a SaaS communication platform',
    bullets: ['Developed a new UI built in react.','Maintained UI library in Figma','Worked in close cooperation with marketing and delivered high scale conference displays all around the world.']
  },
  {
    placement: 'Upsales.com',
    date: 'jan 2018 → sep 2021',
    title: 'UX & UI designer',
    description: 'Built and maintained a CRM & marketing platform',
    bullets: ['Worked in the design team building UI libraries and assets for tech teams', 'Conducted extensive UX research using both quantitive and qualitative research methods']
  },
  {
    placement: 'Knife&Fork.se',
    date: 'jan 2017 → jan 2018',
    title: 'Founder, UX & Front-End Developer',
    description: 'Built a tool for recruiting staff within the service industry',
    bullets: ['Built and maintained a web app using React']
  },
  {
    placement: 'Ellmount Interactive',
    date: '2010 → 2016',
    title: 'Graphic Designer',
    description: 'Designed and maintained several e-gaming platforms',
    bullets: ['Front-end work including PHP, JavaScript and CSS. Lots of focus on payment solutions.','Later switched for more operational role as CPO.']
  },
  {
    placement: 'Bwin Games AB',
    date: '2008 → 2010',
    title: 'Graphic Designer',
    description: 'Worked in Creatives. Delivering production ready solutions for dev teams',
    },
    {
    placement: 'Nilson Group AB',
    date: '2007 → 2008',
    title: 'Graphic Designer',
    description: 'Worked in the marketing department building and maintaining Nilson Groups different e-com sites.',
    },
     {
    placement: 'HB Deck13',
    date: '2003 → 2006',
    title: 'Founder & Graphic Designer',
    description: 'Helped local businesses with their digital presence',
    },
    {
    placement: 'Halogen Sverige AB',
    date: '2003 → 2004',
    title: 'Interface Developer',
    },
    {
    placement: 'Teledrom AB',
    date: '2000 → 2003',
    title: 'Web Designer',
    },
];
---

<Layout title="About | hnrik.com" description="About Henrik Löthman and this photography portfolio.">
  <main class="w-full p-4 sm:p-10 lg:p-12">
    <div class="lg:grid desktop-layout-grid lg:grid-cols-[minmax(180px,16%)_minmax(0,1fr)] lg:gap-x-12">
      <Nav activeTab="about" />
      <div class="about-content px-2 pt-12 pb-16 sm:px-4 sm:pt-14 sm:pb-20 lg:px-6 lg:pt-12 lg:pb-24">
        <section class="space-y-12">
          <h1 class="text-2xl text-black sm:text-4xl" data-reveal style="--reveal-delay: 40ms;">Hi, I'm Henrik</h1>
          <p class="about-intro-text mt-4 text-2xl text-slate-500 leading-relaxed sm:text-4xl" data-reveal style="--reveal-delay: 120ms;">I work as a engineer at <a href="https://www.lyftio.com" class="text-black underline" target="_blank">Lyftio.com</a> where I focus on UI/UX. I do photography as a hobby where I tend to update my <a href="https://www.instagram.com/henriklot/" class="text-black underline" target="_blank">instagram</a> more often than this Astro.js application hosted on Vercel and Contentful as CMS.</p>
        </section>
        <section class="pt-16 space-y-12">
          <p class="text-black text-lg font-semibold" data-reveal style="--reveal-delay: 180ms;">Stuff I've done</p>
          <div class="timeline" data-reveal style="--reveal-delay: 220ms;">
            {
              timeline.map((item, index) => (
                <article
                  class="timeline-item"
                  data-reveal
                  style={`--reveal-delay: ${220 + index * 70}ms;`}
                >
                  <span class="timeline-dot" aria-hidden="true"></span>
                  <div class="timeline-content grid grid-cols-1 gap-y-4 sm:grid-cols-[170px_1fr] sm:gap-x-16">
                    <div class="space-y-2">
                      {item.placement ? <p class="text-black">{item.placement}</p> : null}
                      <p class="text-slate-500 text-sm">{item.date}</p>
                    </div>
                    <div class="timeline-card w-full max-w-2xl text-left">
                      <h2 class="text-lg text-black">{item.title}</h2>
                      {item.description ? <p class="mt-1 text-base leading-relaxed text-slate-600">{item.description}</p> : null}
                    {
                      item.bullets?.length ? (
                        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-slate-500">
                          {item.bullets.map((bullet) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                      ) : null
                    }
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </section>
      </div>
    </div>
  </main>
</Layout>

<style>
  .timeline {
    --timeline-axis: 0.5rem;
    --timeline-content-offset: 2rem;
    --timeline-line-color: #cbd5e1;
    position: relative;
    padding-left: var(--timeline-content-offset);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: var(--timeline-axis);
    top: 0.25rem;
    bottom: 0.25rem;
    width: 1px;
    background: var(--timeline-line-color);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2.75rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    top: calc(0.5rem - 4px);
    left: calc(var(--timeline-axis) - var(--timeline-content-offset));
    width: 1rem;
    height: 1rem;
    transform: translateX(-50%);
    border-radius: 9999px;
    background: var(--theme-bg);
    border: 2px solid var(--timeline-line-color);
  }

  .timeline-content {
    min-width: 0;
  }

  .timeline-card {
    padding-left: 1rem;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(8px);
    animation: reveal-in 520ms ease-out forwards;
    animation-delay: var(--reveal-delay, 0ms);
  }

  @keyframes reveal-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(html[data-theme='dark']) .timeline {
    --timeline-line-color: #334155;
  }

  @media (max-width: 639px) {
    .timeline {
      padding-left: 0;
    }

    .timeline::before {
      display: none;
    }

    .timeline-dot {
      display: none;
    }

    .timeline-card {
      padding-left: 0;
    }
  }

  @media (min-width: 1280px) and (max-width: 1919px) {
    .about-intro-text {
      font-size: clamp(2.25rem, calc(1.75rem + 0.625vw), 2.5rem);
      line-height: 1.6;
    }
  }

  @media (min-width: 1920px) {
    .about-intro-text {
      max-width: 70%;
      font-size: clamp(2.5rem, 3vw, 4.5rem);
      line-height: 1.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
